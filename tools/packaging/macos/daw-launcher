#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
APP_CONTENTS_DIR="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
RES_DIR="$APP_CONTENTS_DIR/Resources"
LOG_DIR="${HOME}/Library/Logs/DAW"
LOG_FILE="$LOG_DIR/launcher.log"
RUNTIME_DIR_DEFAULT="${HOME}/Library/Application Support/DAW/runtime"
RUNTIME_DIR="${DAW_RUNTIME_DIR:-$RUNTIME_DIR_DEFAULT}"

ensure_bundle_copy() {
    target="$1"
    source="$2"
    required_rels="${3:-}"
    if [ -L "$target" ]; then
        rm -rf "$target" 2>/dev/null || true
    fi
    if [ -e "$target" ] && [ -n "$required_rels" ]; then
        old_ifs="${IFS}"
        IFS=':'
        all_present=1
        for required_rel in $required_rels; do
            if [ ! -e "$target/$required_rel" ]; then
                all_present=0
                break
            fi
        done
        IFS="${old_ifs}"
        if [ "$all_present" -eq 1 ]; then
            return 0
        fi
        rm -rf "$target" 2>/dev/null || true
    fi
    [ -e "$source" ] || return 0
    mkdir -p "$(dirname "$target")" 2>/dev/null || true
    if [ -d "$source" ]; then
        /usr/bin/ditto "$source" "$target"
    else
        cp "$source" "$target"
    fi
}

ensure_bundle_link() {
    target="$1"
    source="$2"
    if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -sfn "$source" "$target"
    fi
}

if ! mkdir -p "$RUNTIME_DIR" 2>/dev/null; then
    RUNTIME_DIR="${TMPDIR:-/tmp}/DAW/runtime"
    mkdir -p "$RUNTIME_DIR" 2>/dev/null || true
fi
mkdir -p "$RUNTIME_DIR/vk" "$RUNTIME_DIR/config/shared/shaders" 2>/dev/null || true
if [ ! -f "$RUNTIME_DIR/config/engine.cfg" ]; then
    mkdir -p "$RUNTIME_DIR/config" 2>/dev/null || true
    cp -R "$RES_DIR/config/." "$RUNTIME_DIR/config/" 2>/dev/null || true
fi
ensure_bundle_link "$RUNTIME_DIR/assets" "$RES_DIR/assets"
ensure_bundle_copy "$RUNTIME_DIR/shaders" "$RES_DIR/shaders" "textured.vert.spv:textured.frag.spv:line.vert.spv:line.frag.spv:fill.vert.spv:fill.frag.spv"
ensure_bundle_copy "$RUNTIME_DIR/vk_renderer" "$RES_DIR/vk_renderer" "shaders/textured.vert.spv:shaders/textured.frag.spv:shaders/line.vert.spv:shaders/line.frag.spv:shaders/fill.vert.spv:shaders/fill.frag.spv"
ensure_bundle_link "$RUNTIME_DIR/config/shared/shaders/vk_renderer" "$RUNTIME_DIR/vk_renderer"

mkdir -p "$LOG_DIR" 2>/dev/null || true
if ! touch "$LOG_FILE" 2>/dev/null; then
    LOG_FILE="${TMPDIR:-/tmp}/daw-launcher.log"
    touch "$LOG_FILE" 2>/dev/null || true
fi

export DAW_RUNTIME_DIR="$RUNTIME_DIR"
export VK_RENDERER_SHADER_ROOT="${VK_RENDERER_SHADER_ROOT:-$RUNTIME_DIR}"
export DAW_TIMER_HUD_SETTINGS="${DAW_TIMER_HUD_SETTINGS:-$DAW_RUNTIME_DIR/timerhud/daw/settings.json}"
export DAW_TIMER_HUD="${DAW_TIMER_HUD:-0}"
MOLTENVK_DYLIB="$APP_CONTENTS_DIR/Frameworks/libMoltenVK.dylib"
ICD_FILE="$RUNTIME_DIR/vk/MoltenVK_icd.json"
cat >"$ICD_FILE" <<EOF
{
  "file_format_version": "1.0.0",
  "ICD": {
    "library_path": "$MOLTENVK_DYLIB",
    "api_version": "1.3.0"
  }
}
EOF
export VK_ICD_FILENAMES="${VK_ICD_FILENAMES:-$ICD_FILE}"
export VK_DRIVER_FILES="${VK_DRIVER_FILES:-$ICD_FILE}"
export MOLTENVK_DYLIB

if [ "${1:-}" = "--print-config" ]; then
    echo "APP_CONTENTS_DIR=$APP_CONTENTS_DIR"
    echo "RES_DIR=$RES_DIR"
    echo "LOG_FILE=$LOG_FILE"
    echo "DAW_RUNTIME_DIR=$DAW_RUNTIME_DIR"
    echo "DAW_TIMER_HUD_SETTINGS=$DAW_TIMER_HUD_SETTINGS"
    echo "DAW_TIMER_HUD=$DAW_TIMER_HUD"
    echo "DAW_TIMER_HUD_OVERLAY=${DAW_TIMER_HUD_OVERLAY:-}"
    echo "DAW_TIMER_HUD_VISUAL_MODE=${DAW_TIMER_HUD_VISUAL_MODE:-}"
    echo "VK_RENDERER_SHADER_ROOT=$VK_RENDERER_SHADER_ROOT"
    echo "VK_ICD_FILENAMES=$VK_ICD_FILENAMES"
    echo "VK_DRIVER_FILES=$VK_DRIVER_FILES"
    echo "MOLTENVK_DYLIB=$MOLTENVK_DYLIB"
    exit 0
fi

if [ "${1:-}" = "--self-test" ]; then
    [ -x "$SCRIPT_DIR/daw-bin" ] || { echo "missing: daw-bin" >&2; exit 1; }
    [ -f "$APP_CONTENTS_DIR/Frameworks/libvulkan.1.dylib" ] || { echo "missing: bundled libvulkan" >&2; exit 1; }
    [ -f "$APP_CONTENTS_DIR/Frameworks/libMoltenVK.dylib" ] || { echo "missing: bundled libMoltenVK" >&2; exit 1; }
    [ -f "$APP_CONTENTS_DIR/Info.plist" ] || { echo "missing: Info.plist" >&2; exit 1; }
    [ -f "$RES_DIR/config/engine.cfg" ] || { echo "missing: config/engine.cfg" >&2; exit 1; }
    [ -f "$RES_DIR/assets/audio/README.md" ] || { echo "missing: bundled audio readme" >&2; exit 1; }
    [ -f "$RES_DIR/include/fonts/Montserrat/Montserrat-Regular.ttf" ] || { echo "missing: bundled Montserrat" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/vk_renderer/shaders/textured.vert.spv" ] || { echo "missing: runtime vk renderer textured shader" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/vk_renderer/shaders/line.vert.spv" ] || { echo "missing: runtime vk renderer line shader" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/vk_renderer/shaders/line.frag.spv" ] || { echo "missing: runtime vk renderer line shader" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/vk_renderer/shaders/fill.vert.spv" ] || { echo "missing: runtime vk renderer fill shader" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/vk_renderer/shaders/fill.frag.spv" ] || { echo "missing: runtime vk renderer fill shader" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/shaders/textured.vert.spv" ] || { echo "missing: runtime textured shader" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/shaders/line.vert.spv" ] || { echo "missing: runtime line shader" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/shaders/line.frag.spv" ] || { echo "missing: runtime line shader" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/shaders/fill.vert.spv" ] || { echo "missing: runtime fill shader" >&2; exit 1; }
    [ -f "$RUNTIME_DIR/shaders/fill.frag.spv" ] || { echo "missing: runtime fill shader" >&2; exit 1; }
    [ -f "$ICD_FILE" ] || { echo "missing: runtime MoltenVK_icd.json" >&2; exit 1; }
    echo "self-test: ok"
    echo "LOG_FILE=$LOG_FILE"
    echo "DAW_RUNTIME_DIR=$DAW_RUNTIME_DIR"
    echo "DAW_TIMER_HUD_SETTINGS=$DAW_TIMER_HUD_SETTINGS"
    echo "DAW_TIMER_HUD=$DAW_TIMER_HUD"
    echo "DAW_TIMER_HUD_OVERLAY=${DAW_TIMER_HUD_OVERLAY:-}"
    echo "DAW_TIMER_HUD_VISUAL_MODE=${DAW_TIMER_HUD_VISUAL_MODE:-}"
    echo "VK_RENDERER_SHADER_ROOT=$VK_RENDERER_SHADER_ROOT"
    echo "VK_ICD_FILENAMES=$VK_ICD_FILENAMES"
    echo "VK_DRIVER_FILES=$VK_DRIVER_FILES"
    echo "MOLTENVK_DYLIB=$MOLTENVK_DYLIB"
    exit 0
fi

cd "$RUNTIME_DIR"
printf '%s launch begin pid=%s cwd=%s runtime_dir=%s shader_root=%s args=%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$$" "$RUNTIME_DIR" "$DAW_RUNTIME_DIR" "$VK_RENDERER_SHADER_ROOT" "$*" >>"$LOG_FILE" 2>/dev/null || true
exec "$SCRIPT_DIR/daw-bin" "$@" >>"$LOG_FILE" 2>&1
